# ============================================================
# STRUXAI App - Plantilla de variables de entorno
# Copia a .env y rellena con valores reales (no se sube a git).
# Si despliegas en Vercel: copia estas vars a Project Settings > Env Vars.
# ============================================================

# -----------------------------
# Supabase - struxai-prod (wlxnehlpkpfmlgaythng)
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://wlxnehlpkpfmlgaythng.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SOLO server-side. Nunca prefijar con NEXT_PUBLIC_.

# -----------------------------
# Stripe (billing)
# -----------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# -----------------------------
# Cloudflare R2 (archivos > 50 MB hasta 5 GB single PUT)
# Plan free: 10 GB total, sin egress fee.
# https://dash.cloudflare.com/?to=/:account/r2
# -----------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=struxai-large-files
# Opcional: dominio público (custom domain o r2.dev). Si no se rellena,
# las URLs de descarga se generan vía Worker proxy en backend.
R2_PUBLIC_HOST=

# -----------------------------
# STRUXAI Cloud (VPS propio - openclawd-vps, /srv/struxai-cloud)
# Opt-in en Settings. Cuando el usuario activa el toggle, los
# archivos > 50 MB se enrutan aquí en lugar de R2.
# -----------------------------
STRUXAI_CLOUD_ENDPOINT=https://cloud.struxai.nexusfinlabs.com
STRUXAI_CLOUD_SIGNING_SECRET=cambiar-por-32-bytes-random
